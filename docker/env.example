# MAPDL connection settings
# Use 'mapdl' to connect to the MAPDL container service
# Use 'host.docker.internal' to connect to MAPDL on host (Windows/Mac)
# Use 'localhost' with network_mode: host (Linux)
PYMAPDL_IP=mapdl
PYMAPDL_PORT=50052

# HTTP server settings
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# MAPDL License Server (adjust as needed)
ANSYSLMD_LICENSE_FILE=1055@license-server
